{
  "ci": {
    "collect": {
      "startServerCommand": "npm --prefix apps/web run build && npm --prefix apps/web run start",
      "startServerReadyPattern": "ready|starting",
      "startServerReadyTimeout": 300000,
      "url": [
        "http://127.0.0.1:3000/en",
        "http://127.0.0.1:3000/ar",
        "http://127.0.0.1:3000/booking",
        "http://127.0.0.1:3000/en/destinations/tbilisi"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.60 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:pwa": "off",
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "interactive": ["warn", { "maxNumericValue": 6000 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 600000 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 2000000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
