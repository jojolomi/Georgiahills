{
  "ci": {
    "collect": {
      "staticDistDir": "./apps/web/dist",
      "url": [
        "http://localhost/en.html",
        "http://localhost/booking.html",
        "http://localhost/en/blog/is-georgia-safe.html",
        "http://localhost/en/destinations/tbilisi.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:pwa": "off",
        "largest-contentful-paint": ["warn", { "maxNumericValue": 5000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.15 }],
        "interactive": ["warn", { "maxNumericValue": 6000 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 600000 }],
        "resource-summary:total:size": ["warn", { "maxNumericValue": 2000000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
