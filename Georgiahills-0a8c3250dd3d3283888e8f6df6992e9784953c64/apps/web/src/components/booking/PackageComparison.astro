---
interface Props {
  lang: "en" | "ar";
}

const { lang } = Astro.props;
const isAr = lang === "ar";

const plans = [
  {
    id: "standard",
    icon: "fa-solid fa-car",
    title: isAr ? "برنامج أساسي" : "Standard",
    badge: null,
    priceLabel: isAr ? "تبدأ من" : "From",
    price: isAr ? "٥٠ دولار / يوم" : "$50 / day",
    features: isAr
      ? ["سائق خاص طوال اليوم", "سيارة سيدان مريحة", "استقبال وتوديع المطار", "جدول يومي مخطط", "دعم واتساب"]
      : ["Private driver all day", "Comfortable sedan", "Airport pickup & drop", "Planned daily schedule", "WhatsApp support"],
    text: isAr ? "تنقلات أساسية مع تخطيط يومي عملي." : "Essential private transfers with practical day planning.",
    highlight: false
  },
  {
    id: "vip_family",
    icon: "fa-solid fa-children",
    title: isAr ? "عائلي — حلال فريندلي" : "Family — Halal Friendly",
    badge: isAr ? "الأكثر طلبًا" : "Most Popular",
    priceLabel: isAr ? "تبدأ من" : "From",
    price: isAr ? "٨٠ دولار / يوم" : "$80 / day",
    features: isAr
      ? ["ميني فان مريح للعائلة", "وقفات صلاة مخططة في المسار", "قائمة مطاعم حلال محلية", "أنشطة مناسبة للأطفال", "دعم أولوية عبر واتساب", "استقبال وتوديع VIP"]
      : ["Family minivan", "Prayer stops planned in route", "Local halal restaurant list", "Family-friendly activities", "Priority WhatsApp support", "VIP airport transfers"],
    text: isAr ? "مصمم خصيصًا للعائلات الخليجية مع محطات صلاة ومطاعم حلال." : "Designed for GCC families with prayer stops and halal dining.",
    highlight: true
  },
  {
    id: "luxury",
    icon: "fa-solid fa-gem",
    title: isAr ? "فاخر — أزواج وشهر عسل" : "Luxury — Couples & Honeymoon",
    badge: null,
    priceLabel: isAr ? "تبدأ من" : "From",
    price: isAr ? "١٢٠ دولار / يوم" : "$120 / day",
    features: isAr
      ? ["سيارة فاخرة (SUV / سيدان VIP)", "مسارات رومانسية مختارة", "حجوزات مطاعم راقية", "تنسيق إقامة فندقية", "خدمة 24 ساعة"]
      : ["Luxury SUV / VIP sedan", "Curated romantic routes", "Fine dining reservations", "Hotel coordination", "24-hour concierge"],
    text: isAr ? "مركبة أرقى ومسارات محسنة للأزواج وشهر العسل." : "Higher-tier vehicle and elevated couple-focused routes.",
    highlight: false
  }
];
---
<section class="section-py package-comparison" aria-labelledby="package-comparison-title">
  <div class="container">
    <h2 id="package-comparison-title" class="section-title">{isAr ? "اختر باقتك" : "Choose Your Package"}</h2>
    <p class="section-desc" style="margin-bottom:2rem;">{isAr ? "جميع الباقات تشمل سائقًا خاصًا مع تنسيق مسبق وخدمة واتساب سريعة." : "All packages include a private driver, pre-trip planning, and fast WhatsApp service."}</p>
    <div class="package-grid">
      {plans.map((plan) => (
        <article
          class={`content-card package-card${plan.highlight ? " package-card--featured" : ""}`}
          style={plan.highlight ? "border:2px solid var(--color-primary); position:relative;" : ""}
        >
          {plan.badge && (
            <span class="package-badge" style="position:absolute; top:-0.75rem; left:50%; transform:translateX(-50%); background:var(--color-primary); color:white; font-size:0.75rem; font-weight:700; padding:0.25rem 0.75rem; border-radius:999px; white-space:nowrap;">
              {plan.badge}
            </span>
          )}
          <div style="text-align:center; margin-bottom:1rem;">
            <i class={plan.icon} style="font-size:2rem; color:var(--color-primary);"></i>
          </div>
          <h3 style="text-align:center; margin-bottom:0.5rem;">{plan.title}</h3>
          <p class="package-price" style="text-align:center; font-size:1.4rem; font-weight:800; color:var(--color-primary); margin-bottom:1rem;">
            <span style="font-size:0.8rem; font-weight:400; color:var(--color-gray-500);">{plan.priceLabel} </span>{plan.price}
          </p>
          <ul style="list-style:none; padding:0; margin:0 0 1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
            {plan.features.map((f) => (
              <li style="display:flex; align-items:flex-start; gap:0.5rem; font-size:0.9rem; color:var(--color-gray-700);">
                <i class="fa-solid fa-circle-check" style="color:var(--color-primary); margin-top:0.1rem; flex-shrink:0;"></i>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <p style="font-size:0.85rem; color:var(--color-gray-500); margin-bottom:1.25rem;">{plan.text}</p>
          <a
            href={isAr ? "/booking-ar.html" : "/booking.html"}
            class={`btn-hero ${plan.highlight ? "btn-hero-primary" : "btn-hero-secondary"} package-cta`}
            data-book-plan={plan.id}
            data-ga4-event="package_cta_click"
            data-ga4-label={plan.id}
            style="width:100%; text-align:center; display:block;"
          >
            {isAr ? "احجز هذه الخطة" : "Book this plan"}
          </a>
        </article>
      ))}
    </div>
    <p class="contact-disclosure" style="text-align:center; margin-top:1.5rem;">{isAr ? "الأسعار تقريبية وتُحدد بعد مراجعة تفاصيل الرحلة. لا حجز مسبق بدون تأكيد مكتوب." : "Prices are indicative and confirmed after reviewing trip details. No booking without written confirmation."}</p>
  </div>
</section>

<script>
  document.querySelectorAll("[data-ga4-event]").forEach(function(el) {
    el.addEventListener("click", function() {
      var eventName = el.dataset.ga4Event;
      var label = el.dataset.ga4Label || "";
      if (typeof window.gtag === "function" && eventName) {
        window.gtag("event", eventName, { event_label: label });
      }
    });
  });
</script>
