---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ensureSeoContract } from "../components/seo/contract";
import { breadcrumbSchema, localBusinessSchema } from "../components/seo/schema-builders";
import { SITE } from "../config/site";
import NewsletterSignup from "../components/marketing/NewsletterSignup.astro";

const allPosts = await getCollection("blog");
const arPosts = allPosts
  .filter((p) => p.data.lang === "ar")
  .sort((a, b) => {
    const dateA = a.data.date ?? a.data.publish_date ?? "2026-01-01";
    const dateB = b.data.date ?? b.data.publish_date ?? "2026-01-01";
    return dateB.localeCompare(dateA);
  });

const canonical = `${SITE.domain}/blog-ar.html`;

const meta = ensureSeoContract(
  {
    lang: "ar",
    dir: "rtl",
    title: "مدونة Georgia Hills | نصائح السفر إلى جورجيا للمسافر الخليجي",
    description: "مقالات عملية حول السفر إلى جورجيا: برامج، تكاليف، أمان، سفر حلال ونصائح للعائلات الخليجية.",
    canonical,
    hreflangs: [
      { hreflang: "ar", href: canonical },
      { hreflang: "en", href: `${SITE.domain}/blog.html` },
      { hreflang: "x-default", href: `${SITE.domain}/` }
    ],
    ogImage: `${SITE.domain}/image-1600.webp`,
    robots: "index, follow, max-image-preview:large",
    twitterCard: "summary_large_image",
    schemaGraph: [
      localBusinessSchema(canonical),
      {
        "@type": "WebPage",
        name: "مدونة Georgia Hills",
        inLanguage: "ar",
        url: canonical,
        description: "مقالات سفر عملية للمسافرين من الخليج إلى جورجيا"
      },
      breadcrumbSchema([
        { name: "الرئيسية", item: `${SITE.domain}/arabic.html` },
        { name: "المدونة", item: canonical }
      ])
    ]
  },
  "blog-ar"
);

const intentLabels: Record<string, string> = {
  planning: "تخطيط",
  cost: "ميزانية",
  itinerary: "برنامج",
  halal: "حلال",
  safety: "أمان"
};
---
<BaseLayout lang="ar" dir="rtl" meta={meta}>
  <section class="section-py" style="padding-top:7rem; padding-bottom:3rem;">
    <div class="container">
      <h1 class="section-title" style="margin-bottom:0.5rem;">المدونة</h1>
      <p class="section-desc" style="margin-bottom:2.5rem;">
        نصائح عملية ومقالات سفر مخصصة للمسافر الخليجي إلى جورجيا.
      </p>

      {arPosts.length === 0 && (
        <p style="color:var(--color-gray-500);">لا توجد مقالات متاحة حاليًا.</p>
      )}

      <div class="package-grid">
        {arPosts.map((post) => {
          const fm = post.data;
          const postUrl = `/blog/${post.id}.html`;
          const postTitle = fm.meta_title ?? fm.metaTitle ?? fm.title;
          const postDesc = fm.meta_description ?? fm.metaDescription ?? fm.description;
          const intentLabel = fm.intent ? (intentLabels[fm.intent] ?? fm.intent) : null;
          return (
            <article class="content-card blog-card" style="padding:1.5rem; display:flex; flex-direction:column; gap:0.75rem;">
              {fm.image && (
                <img
                  src={fm.image}
                  alt={postTitle}
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="360"
                  style="width:100%; border-radius:0.5rem; object-fit:cover; aspect-ratio:16/9;"
                />
              )}
              <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                {fm.date && (
                  <time datetime={fm.date} style="font-size:0.8rem; color:var(--color-gray-500);">{fm.date}</time>
                )}
                {intentLabel && (
                  <span style="font-size:0.75rem; background:var(--color-primary); color:white; border-radius:999px; padding:0.1rem 0.6rem;">{intentLabel}</span>
                )}
              </div>
              <h2 style="font-size:1.1rem; font-weight:700; line-height:1.4; margin:0;">{postTitle}</h2>
              <p style="color:var(--color-gray-600); font-size:0.9rem; line-height:1.6; margin:0; flex:1;">{postDesc}</p>
              <a
                href={postUrl}
                class="btn-hero btn-hero-primary"
                style="align-self:flex-start; font-size:0.875rem;"
                data-ga4-event="blog_listing_click"
                data-ga4-label={post.id}
              >
                اقرأ المزيد
              </a>
            </article>
          );
        })}
      </div>

      <div class="hero-buttons" style="margin-top:3rem; justify-content:center;">
        <a href="/booking-ar.html" class="btn-hero btn-hero-primary" data-ga4-event="blog_ar_cta_click">
          احجز رحلتك
        </a>
        <a
          href="https://wa.me/995579088537"
          class="btn-hero btn-hero-secondary"
          target="_blank"
          rel="noopener noreferrer"
          data-ga4-event="whatsapp_click"
          data-ga4-label="blog-ar-page"
        >
          تواصل واتساب
        </a>
      </div>
    </div>
  </section>
  <NewsletterSignup lang="ar" />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>("[data-ga4-event]").forEach((el) => {
    el.addEventListener("click", () => {
      const eventName = el.dataset.ga4Event;
      const label = el.dataset.ga4Label ?? "";
      if (typeof window.gtag === "function" && eventName) {
        window.gtag("event", eventName, { event_label: label });
      }
    });
  });
</script>
