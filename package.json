{
  "name": "georgiahills",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lockfile:sync": "corepack pnpm install --lockfile-only --ignore-scripts",
    "lockfile:check": "corepack pnpm install --frozen-lockfile --ignore-scripts",
    "lockfile:check:functions": "npm --prefix functions ci --no-audit --no-fund --dry-run",
    "preflight:pr": "npm run lockfile:check && npm run lockfile:check:functions && npm run ops:firebase-config-guard && npm run ops:legacy-html-coverage && npm run ops:locale-rtl-parity && npm run seo:validate:markets && npm run ops:imports:case && npm run ops:netlify-cache-policy && npm run perf:mobile-targets && npm run perf:critical-path:audit && npm run perf:critical-path:budget && npm run perf:dom-size:audit && npm run perf:dom-budget && npm run perf:third-party-governance && npm run perf:lighthouse:config && npm run perf:legacy-assets && npm run perf:article-runtime-split && npm run perf:blog-runtime-split && npm run ops:architecture-cleanup-readiness && npm run lint && npm run typecheck && npm run test:unit",
    "lint": "corepack pnpm --filter web lint",
    "typecheck": "corepack pnpm --filter web typecheck",
    "test:unit": "corepack pnpm --filter web test:unit",
    "test:e2e:core": "playwright test --config=playwright.core.config.js",
    "check": "node scripts/site-check.js",
    "seo:engine": "node scripts/seo-engine.js",
    "images:optimize": "node scripts/optimize-images.js",
    "dev:astro": "npm --prefix astro-site run dev",
    "build:astro": "npm --prefix astro-site ci --no-audit --no-fund && npm --prefix astro-site run build",
    "preview:astro": "npm --prefix astro-site run preview",
    "dev:admin-v3": "npm --prefix admin-v3 run dev",
    "build:admin-v3": "npm run ops:imports:case && npm --prefix admin-v3 ci --no-audit --no-fund && npm --prefix admin-v3 run build",
    "build:admin-v3:hosting": "npm run build:admin-v3 && node scripts/prepare-admin-v3-hosting.js",
    "preview:admin-v3": "npm --prefix admin-v3 run preview",
    "seo:validate:hreflang": "node scripts/validate-hreflang.js astro-site/dist",
    "seo:validate:schema": "node scripts/validate-schema.js astro-site/dist",
    "seo:validate:links": "node scripts/check-broken-links.js astro-site/dist",
    "seo:validate:keywords": "node scripts/audit/seo/check-keyword-entities.js astro-site/dist",
    "seo:validate:legal": "node scripts/audit/seo/check-legal-links.js astro-site/dist",
    "seo:validate:markets": "node scripts/audit/seo/check-market-hreflang.js",
    "seo:validate:parity": "node scripts/audit/seo/check-locale-content-parity.js",
    "seo:validate": "npm run seo:validate:hreflang && npm run seo:validate:schema && npm run seo:validate:links && npm run seo:validate:keywords && npm run seo:validate:legal && npm run seo:validate:markets && npm run seo:validate:parity",
    "perf:asset-budget": "node scripts/audit/perf/asset-budget.js astro-site/dist",
    "perf:legacy-assets": "node scripts/audit/perf/check-legacy-minified-assets.js",
    "perf:article-runtime-split": "node scripts/audit/perf/check-article-runtime-split.js",
    "perf:blog-runtime-split": "node scripts/audit/perf/check-blog-runtime-split.js",
    "perf:mobile-targets": "node scripts/audit/perf/check-mobile-template-targets.js",
    "perf:critical-path:audit": "node scripts/audit/perf/audit-template-critical-path.js",
    "perf:critical-path:budget": "node scripts/audit/perf/check-template-critical-path-budget.js",
    "perf:dom-size:audit": "node scripts/audit/perf/audit-template-dom-size.js",
    "perf:dom-budget": "node scripts/audit/perf/check-dom-simplification-budget.js",
    "perf:third-party-governance": "node scripts/audit/perf/check-third-party-governance.js",
    "perf:lighthouse:config": "node scripts/audit/perf/check-lighthouse-config.js .lighthouserc.json",
    "perf:render-blocking-css": "node scripts/audit/perf/check-render-blocking-external-css.js",
    "ops:runtime-parity": "node scripts/audit/ops/check-runtime-parity.js",
    "ops:runtime-parity:local": "node -e \"process.env.ALLOW_NODE_RUNTIME_MISMATCH='true'; process.env.GH_ENVIRONMENT=process.env.GH_ENVIRONMENT || 'local'; require('./scripts/audit/ops/check-runtime-parity.js');\"",
    "ops:firebase-config-guard": "node scripts/audit/ops/check-tracked-firebase-config.js",
    "ops:legacy-html-coverage": "node scripts/audit/ops/check-legacy-html-coverage.js",
    "ops:locale-rtl-parity": "node scripts/audit/ops/check-locale-rtl-parity.js",
    "ops:architecture-cleanup-readiness": "node scripts/audit/ops/check-architecture-cleanup-readiness.js",
    "ops:cutover:smoke": "node scripts/audit/ops/check-cutover-smoke.js",
    "ops:cutover:smoke:warn": "node scripts/audit/ops/check-cutover-smoke.js https://georgiahills.com warn",
    "ops:cutover:smoke:strict": "node scripts/audit/ops/check-cutover-smoke.js https://georgiahills.com strict",
    "ops:delivery:slo:warn": "node scripts/audit/ops/check-delivery-slo.js https://georgiahills.com warn",
    "ops:delivery:slo:strict": "node scripts/audit/ops/check-delivery-slo.js https://georgiahills.com strict",
    "ops:cutover:smoke:local": "node scripts/audit/ops/run-cutover-smoke-local.js warn",
    "ops:cutover:smoke:local:strict": "node scripts/audit/ops/run-cutover-smoke-local.js strict",
    "release:verify": "npm run preflight:pr && npm run build:astro && npm run seo:validate && npm run perf:asset-budget && npm run perf:render-blocking-css && npm run test:a11y && npm run ops:cutover:smoke:strict",
    "ops:imports:case": "node scripts/audit/ops/check-import-case.js admin-v3/src",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "lighthouse:assert:mobile": "node scripts/check-lighthouse-threshold.js reports/lighthouse/en-mobile.json && node scripts/check-lighthouse-threshold.js reports/lighthouse/ar-mobile.json",
    "seo:prepare": "node scripts/generate-sitemap.js && npm run build:astro",
    "test": "npm run check && npm run ops:firebase-config-guard && npm --prefix functions test",
    "test:crossbrowser": "playwright test",
    "test:a11y": "playwright test --config=playwright.a11y.config.js",
    "test:admin-v3": "npm run build:astro && npm run build:admin-v3:hosting && playwright test --config=playwright.admin-v3.config.js",
    "test:admin-v3:auth": "npm run build:astro && npm run build:admin-v3:hosting && playwright test --config=playwright.admin-v3.auth.config.js",
    "test:browserstack": "browserstack-node-sdk playwright test",
    "ops:firebase-cost": "node scripts/audit/ops/check-firebase-cost-threshold.js"
    ,"ops:netlify-cache-policy": "node scripts/audit/ops/check-netlify-cache-policy.js"
  },
  "dependencies": {
    "firebase": "^12.12.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.55.0",
    "browserstack-node-sdk": "^1.35.6",
    "http-server": "^14.1.1",
    "sharp": "^0.34.5"
  }
}
