{
  "name": "georgiahills",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "images:convert": "node infrastructure/convert-images.js",
    "check": "node scripts/site-check.js",
    "seo:engine": "node scripts/seo-engine.js",
    "images:optimize": "node scripts/optimize-images.js",
    "dev:astro": "corepack pnpm --filter ./apps/web dev",
    "build:astro": "corepack pnpm --filter ./apps/web build",
    "preview:astro": "corepack pnpm --filter ./apps/web start",
    "dev:admin-v3": "corepack pnpm --filter ./apps/admin dev",
    "build:admin-v3": "corepack pnpm --filter ./apps/admin build",
    "build:admin-v3:hosting": "npm run build:admin-v3 && node scripts/prepare-admin-v3-hosting.js",
    "preview:admin-v3": "corepack pnpm --filter ./apps/admin preview",
    "seo:validate:hreflang": "node scripts/validate-hreflang.js apps/web/dist",
    "seo:validate:schema": "node scripts/validate-schema.js apps/web/dist",
    "seo:validate:links": "node scripts/check-broken-links.js apps/web/dist",
    "seo:validate:keywords": "node scripts/audit/seo/check-keyword-entities.js apps/web/dist",
    "seo:validate:legal": "node scripts/audit/seo/check-legal-links.js apps/web/dist",
    "seo:prepare": "node scripts/prepare-seo-dist.js",
    "seo:validate": "npm run seo:prepare && npm run seo:validate:hreflang && npm run seo:validate:schema && npm run seo:validate:links && npm run seo:validate:keywords && npm run seo:validate:legal",
    "perf:asset-budget": "node scripts/audit/perf/asset-budget.js apps/web/dist",
    "ops:runtime-parity": "node scripts/audit/ops/check-runtime-parity.js",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "lint": "corepack pnpm --filter web lint",
    "typecheck": "corepack pnpm --filter web typecheck",
    "test:unit": "npm --prefix functions test",
    "test:e2e:core": "playwright test --config=playwright.core.config.js",
    "test": "npm run check && npm --prefix functions test",
    "test:crossbrowser": "playwright test",
    "test:admin-v3": "npm run build:astro && npm run build:admin-v3:hosting && playwright test --config=playwright.admin-v3.config.js",
    "test:admin-v3:auth": "npm run build:astro && npm run build:admin-v3:hosting && playwright test --config=playwright.admin-v3.auth.config.js",
    "test:browserstack": "browserstack-node-sdk playwright test",
    "ops:firebase-cost": "node scripts/audit/ops/check-firebase-cost-threshold.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "next-mdx-remote": "^6.0.0",
    "pg": "^8.19.0",
    "react-hook-form": "^7.71.2",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.55.0",
    "@types/pg": "^8.18.0",
    "autoprefixer": "^10.4.27",
    "browserstack-node-sdk": "^1.35.6",
    "http-server": "^14.1.1",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17"
  }
}
