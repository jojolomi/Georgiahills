{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@gh/ui": ["../../packages/ui/src/index.ts"],
      "@gh/ui/*": ["../../packages/ui/src/*"],
      "@gh/lib": ["../../packages/lib/src/index.ts"],
      "@gh/lib/*": ["../../packages/lib/src/*"],
      "@gh/types": ["../../packages/types/src/index.ts"],
      "@gh/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
